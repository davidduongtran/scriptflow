{
  "manifest_version": 3,
  "name": "TITANSYS MIND",
  "version": "7.0.0",
  "description": "AI Script & Prompt Generation - TITANSYS (Modular Architecture)",
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "TITANSYS MIND v7.0",
    "default_icon": "icons/icon48.png"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "data/*.js",
        "modules/*.js"
      ],
      "matches": [
        "chrome-extension://*/*"
      ]
    }
  ]
}