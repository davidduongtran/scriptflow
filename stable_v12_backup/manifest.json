{
  "manifest_version": 3,
  "name": "ScriptWriter Pro",
  "version": "12.1212.0",
  "description": "AI-Powered YouTube Script & VEO 3 Prompt Generation",
  "permissions": [
    "storage",
    "sidePanel",
    "activeTab"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "ScriptWriter Pro V12 Stable 1212",
    "default_icon": "icons/icon48.png"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "externally_connectable": {
    "ids": [
      "*"
    ]
  }
}